# ==========================================
# Frontend Variables (Used by Next.js / Vercel)
# ==========================================
# In production on Vercel, set this to your Render URL:
# NEXT_PUBLIC_API_URL=https://your-render-url.onrender.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ==========================================
# Backend Variables (Used by FastAPI / Render)
# ==========================================
# SQLite for local dev, PostgreSQL/MySQL for Prod
DATABASE_URL=sqlite:///./sql_app.db

# Security
JWT_SECRET=supersecretkey_for_fraudshield_ai_enterprise
# In production on Render, restrict to your Vercel URL:
# ALLOWED_ORIGINS=https://your-vercel-app-url.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
